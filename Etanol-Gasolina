def menuPrecos():
    print("\n--- MENU DE OPÇÕES ---")
    print("1. Calcular Preço do Etanol/Gasolina")
    print("2. Calcular Valor IPVA")
    print("3. Sair")
    return input("Escolha uma opção: ")


while True:
    opcao = menuPrecos()

    if opcao == "1":
        precoEtanolPorLitro = float(input("Digite o preço do etanol: R$ "))
        precoGasolinaPorLitro = float(input("Digite o preço da gasolina: R$ "))

        valor = (precoEtanolPorLitro / precoGasolinaPorLitro) * 100

        print(f"Relação etanol/gasolina: {valor:.2f}%")

        if valor <= 70:
            print("O etanol vale mais a pena")
        else:
            print("A gasolina vale mais a pena")

        print(f"Preço do etanol: R$ {precoEtanolPorLitro:.2f}")
        print(f"Preço da gasolina: R$ {precoGasolinaPorLitro:.2f}")
        
    elif opcao == "2":  
        anoDoCarro = int(input("Digite o ano de fabricação do carro:"))
        valorDoCarro = float(input("Digite o valor do seu carro, segundo a FIPE: R$"))
        aliquota = float(input("Digite o valor da alíquota do IPVA do seu estado(%):"))
        
        if anoDoCarro <= 2006:
            valorIPVA = 0
        
        else:
            valorIPVA = valorDoCarro * (aliquota/100)
        
        print(f"O ano do seu carro é: {anoDoCarro}") 
        print(f"O valor do IPVA a ser pago será: R$ {valorIPVA:.2f}")

    elif opcao == "3":
        print("Programa encerrado.")
        break

    else:
        print("Opção inválida, tente novamente.")
