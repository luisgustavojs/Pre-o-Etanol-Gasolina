<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <title>Calculadora</title>

    <style>

        body{
            font-family: Arial;
            background-color: #222;
            color: white;
            padding: 30px;
        }

        .box{
            background-color: #333;
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
        }

        input{
            margin: 5px;
            padding: 8px;
        }

        button{
            padding: 10px;
            cursor: pointer;
        }

    </style>

</head>

<body>

    <h1>Calculadora de Combustível e IPVA</h1>

    <div class="box">

        <h2>Etanol vs Gasolina</h2>

        <form method="POST">

            <input type="hidden" name="tipo" value="combustivel">

            <input type="number" step="0.01" name="etanol" placeholder="Preço Etanol" required>

            <input type="number" step="0.01" name="gasolina" placeholder="Preço Gasolina" required>

            <button type="submit">Calcular</button>

        </form>

    </div>

    <div class="box">

        <h2>Calcular IPVA</h2>

        <form method="POST">

            <input type="hidden" name="tipo" value="ipva">

            <input type="number" step="0.01" name="carro" placeholder="Valor do carro" required>

            <input type="number" step="0.01" name="aliquota" placeholder="Alíquota (%)" required>

            <button type="submit">Calcular</button>

        </form>

    </div>

    <div class="box">
        <h2>Resultado</h2>
        <p>{{ resultado|safe }}</p>
    </div>

</body>

</html>
