<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema Automotivo</title>

    <style>

        body{
            font-family: Arial, Helvetica, sans-serif;
            background-color: #f4f4f4;
            padding: 30px;
        }

        h1{
            color: #333;
        }

        .caixa{
            background: white;
            padding: 20px;
            margin-bottom: 20px;
            border-radius: 10px;
            box-shadow: 0px 0px 10px rgba(0,0,0,0.1);
        }

        input, select, button{
            width: 100%;
            padding: 10px;
            margin-top: 10px;
            margin-bottom: 10px;
        }

        button{
            background-color: #007BFF;
            color: white;
            border: none;
            cursor: pointer;
        }

        button:hover{
            background-color: #0056b3;
        }

        .resultado{
            margin-top: 15px;
            padding: 10px;
            background-color: #e9ecef;
            border-radius: 5px;
        }

    </style>

</head>
<body>

    <h1>Sistema Automotivo</h1>

    <!-- ========================= -->
    <!-- COMBUSTÍVEL -->
    <!-- ========================= -->

    <div class="caixa">

        <h2>Etanol ou Gasolina</h2>

        <form method="POST">

            <input type="hidden" name="tipo" value="combustivel">

            <label>Preço do Etanol:</label>
            <input type="number" step="0.01" name="etanol" required>

            <label>Preço da Gasolina:</label>
            <input type="number" step="0.01" name="gasolina" required>

            <button type="submit">Calcular</button>

        </form>

    </div>

    <!-- ========================= -->
    <!-- IPVA -->
    <!-- ========================= -->

    <div class="caixa">

        <h2>Calcular IPVA</h2>

        <form method="POST">

            <input type="hidden" name="tipo" value="ipva">

            <label>Valor do carro:</label>
            <input type="number" step="0.01" name="carro" required>

            <label>Alíquota (%):</label>
            <input type="number" step="0.01" name="aliquota" required>

            <button type="submit">Calcular IPVA</button>

        </form>

    </div>

    <!-- ========================= -->
    <!-- DETALHES DOS CARROS -->
    <!-- ========================= -->

    <div class="caixa">

        <h2>Detalhes dos Carros</h2>

        <form method="POST">

            <input type="hidden" name="tipo" value="detalhes">

            <label>Escolha um carro:</label>

            <select name="indice">

                {% for carro in carros %}

                    <option value="{{ loop.index0 }}">
                        {{ carro.marca }} - {{ carro.modelo }}
                    </option>

                {% endfor %}

            </select>

            <button type="submit">Ver Detalhes</button>

        </form>

    </div>

    <!-- ========================= -->
    <!-- RESULTADOS -->
    <!-- ========================= -->

    {% if resultado %}

        <div class="caixa resultado">
            {{ resultado|safe }}
        </div>

    {% endif %}

    {% if detalhesCarro %}

        <div class="caixa resultado">
            {{ detalhesCarro|safe }}
        </div>

    {% endif %}

</body>
</html>
