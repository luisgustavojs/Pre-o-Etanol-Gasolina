<!DOCTYPE html>
<html lang="pt-br">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Sistema Automotivo</title>

    <!-- CONEXÃO COM O CSS -->
    <link
    rel="stylesheet"
    href="{{ url_for('static', filename='style.css') }}">

</head>

<body>

    <!-- ========================= -->
    <!-- NAVBAR -->
    <!-- ========================= -->

    <div class="navbar">

        <h1>Sistema Automotivo</h1>

    </div>

    <div class="container">

        <!-- ========================= -->
        <!-- COMBUSTÍVEL -->
        <!-- ========================= -->

        <div class="caixa">

            <h2>Etanol ou Gasolina</h2>

            <form method="POST">

                <input type="hidden" name="tipo" value="combustivel">

                <label>Preço do Etanol:</label>

                <input
                type="number"
                step="0.01"
                name="etanol"
                required>

                <label>Preço da Gasolina:</label>

                <input
                type="number"
                step="0.01"
                name="gasolina"
                required>

                <button type="submit">
                    Calcular
                </button>

            </form>

        </div>

        <!-- ========================= -->
        <!-- IPVA -->
        <!-- ========================= -->

        <div class="caixa">

            <h2>Calcular IPVA</h2>

            <form method="POST">

                <input type="hidden" name="tipo" value="ipva">

                <label>Valor do carro:</label>

                <input
                type="number"
                step="0.01"
                name="carro"
                required>

                <label>Alíquota (%):</label>

                <input
                type="number"
                step="0.01"
                name="aliquota"
                required>

                <button type="submit">
                    Calcular IPVA
                </button>

            </form>

        </div>

        <!-- ========================= -->
        <!-- DETALHES DOS CARROS -->
        <!-- ========================= -->

        <div class="caixa">

            <h2>Detalhes dos Carros</h2>

            <form method="POST">

                <input type="hidden" name="tipo" value="detalhes">

                <label>Escolha um carro:</label>

                <select name="indice">

                    {% for carro in carros %}

                        <option value="{{ loop.index0 }}">

                            {{ carro.marca }}
                            -
                            {{ carro.modelo }}

                        </option>

                    {% endfor %}

                </select>

                <button type="submit">
                    Ver Detalhes
                </button>

            </form>

        </div>

        <!-- ========================= -->
        <!-- RESULTADOS -->
        <!-- ========================= -->

        {% if resultado %}

            <div class="caixa resultado">

                {{ resultado|safe }}

            </div>

        {% endif %}

        {% if detalhesCarro %}

            <div class="caixa resultado">

                {{ detalhesCarro|safe }}

            </div>

        {% endif %}

        <!-- ========================= -->
        <!-- CARDS DOS VEÍCULOS -->
        <!-- ========================= -->

        <h2>Veículos Disponíveis</h2>

        <div class="cards">

            {% for carro in carros %}

            <div class="card">

                <img
                class="imagem-carro"
                src="{{ url_for('static', filename=carro.imagem) }}">

                <div class="info">

                    <img
                    class="logo"
                    src="{{ url_for('static', filename=carro.logo) }}">

                    <h2 class="modelo">

                        {{ carro.marca }}
                        {{ carro.modelo }}

                    </h2>

                    <p class="ano">

                        Ano:
                        {{ carro.ano }}

                    </p>

                    <p class="preco">

                        R$

                        {{ "{:,.2f}".format(carro.preco)
                        .replace(",", "X")
                        .replace(".", ",")
                        .replace("X", ".") }}

                    </p>

                    <a href="#" class="botao">

                        Ver detalhes

                    </a>

                </div>

            </div>

            {% endfor %}

        </div>

    </div>

</body>
</html>
