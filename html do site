<!DOCTYPE html>
<html lang="pt-br">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Sistema Automotivo</title>

    <link
rel="stylesheet"
href="{{ url_for('static', filename='style.css') }}">

</head>

<body>

    <!-- NAVBAR -->

    <div class="navbar">
        <h1>Sistema Automotivo</h1>
    </div>

    <div class="container">

        <!-- BUSCA -->

        <div class="caixa">

            <h2>Buscar Veículo</h2>

            <form method="GET">

                <input
                type="text"
                name="busca"
                value="{{ request.args.get('busca', '') }}"
                placeholder="Marca, modelo ou categoria">

                <button type="submit">
                    Buscar
                </button>

            </form>

        </div>

        <!-- ETANOL OU GASOLINA -->

        <div class="caixa">

            <h2>Etanol ou Gasolina</h2>

            <form method="POST">

                <input type="hidden" name="tipo" value="combustivel">

                <label>Preço do Etanol:</label>

                <input
                type="number"
                step="0.01"
                name="etanol"
                required>

                <label>Preço da Gasolina:</label>

                <input
                type="number"
                step="0.01"
                name="gasolina"
                required>

                <button type="submit">
                    Calcular
                </button>

            </form>

        </div>

        <!-- IPVA -->

        <div class="caixa">

            <h2>Calcular IPVA</h2>

            <form method="POST">

                <input type="hidden" name="tipo" value="ipva">

                <label>Ano do carro:</label>

                <input
                type="number"
                name="ano"
                required>

                <label>Valor do carro:</label>

                <input
                type="number"
                step="0.01"
                name="carro"
                required>

                <label>Alíquota (%):</label>

                <input
                type="number"
                step="0.01"
                name="aliquota"
                required>

                <button type="submit">
                    Calcular IPVA
                </button>

            </form>

        </div>

        <!-- DETALHES DOS CARROS -->

        <div class="caixa">

            <h2>Detalhes dos Carros</h2>

            <form method="POST">

                <input type="hidden" name="tipo" value="detalhes">

                <label>Escolha um carro:</label>

                <select name="indice">

                    {% for carro in carros %}

                    <option value="{{ loop.index0 }}">
                        {{ carro.marca }} - {{ carro.modelo }}
                    </option>

                    {% endfor %}

                </select>

                <button type="submit">
                    Ver Detalhes
                </button>

            </form>

        </div>

        <!-- RESULTADOS -->

        {% if resultado %}

        <div class="caixa resultado">
            {{ resultado|safe }}
        </div>

        {% endif %}

        {% if detalhesCarro %}

        <div class="caixa resultado">
            {{ detalhesCarro|safe }}
        </div>

        {% endif %}

        <!-- NENHUM RESULTADO -->

        {% if carros|length == 0 %}

        <div class="caixa">

            <h3>Nenhum veículo encontrado.</h3>

        </div>

        {% endif %}

        <!-- CARDS -->

        <h2>Veículos Disponíveis</h2>

        <div class="cards">

            {% for carro in carros %}

            <div class="card">

                <img
                class="imagem-carro"
                src="{{ url_for('static', filename=carro.imagem) }}"
                alt="{{ carro.modelo }}">

                <div class="info">

                    <img
                    class="logo"
                    src="{{ url_for('static', filename=carro.logo) }}"
                    alt="{{ carro.marca }}">

                    <h2 class="modelo">
                        {{ carro.marca }} {{ carro.modelo }}
                    </h2>

                    <p class="ano">
                        Ano: {{ carro.ano }}
                    </p>

                    <p class="categoria">
                        Categoria: {{ carro.categoria }}
                    </p>

                    <p class="preco">
                        R$
                        {{ "{:,.2f}".format(carro.preco)
                        .replace(",", "X")
                        .replace(".", ",")
                        .replace("X", ".") }}
                    </p>

                    <a href="#" class="botao">
                        Ver detalhes
                    </a>

                </div>

            </div>

            {% endfor %}

        </div>

    </div>

</body>
</html>
